# Copy this file to .env.local and fill in real values.
# DEMO_FREE_JOBS=true enables fully free demo mode:
# - /api/demo/* routes bypass Lightning
# - worker claim/deliver bypasses Lightning payout/deposit
# No wallet daemons required.

MDK_WALLET_URL=http://localhost:3456
MDK_AGENT_WALLET_URL=http://localhost:3457

# Phase 6 worker — OpenAI-compatible LLM provider.
# Recommended: Groq (free, ~1s/call). Get a key at https://console.groq.com
MODAL_API_KEY=your-groq-key-here
MODAL_BASE_URL=https://api.groq.com/openai/v1
MODAL_MODEL=llama-3.3-70b-versatile
MODAL_MAX_TOKENS=4096

# Alternative providers (any OpenAI-compatible /v1/chat/completions endpoint):
#   Cerebras:  https://api.cerebras.ai/v1            llama-3.3-70b
#   Together:  https://api.together.xyz/v1           meta-llama/Llama-3.3-70B-Instruct-Turbo
#   Modal:     https://api.us-west-2.modal.direct/v1 zai-org/GLM-5.1-FP8  (reasoning model — set MAX_TOKENS=8192)

# Optional — enables web-fetch enrichment on summarize jobs whose input is a URL
TAVILY_API_KEY=

MARKETPLACE_FEE_PERCENT=10
JOB_EXPIRY_MINUTES=30
CLAIM_WINDOW_MINUTES=10
CLAIM_DEPOSIT_SATS=2

# Any 32+ character random string. Must match across teammates sharing wallet state.
L402_HMAC_SECRET=change-me-to-a-long-random-string

# Set to false (or remove) on demo day when wallets are funded with real sats.
DEMO_FREE_JOBS=true

# Where the agents (requester.js / worker.js) reach the Next.js server.
MARKETPLACE_URL=http://localhost:3000
